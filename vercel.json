{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/v/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/widget.js",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/recall",
      "schedule": "0 9 * * *"
    }
  ]
}
